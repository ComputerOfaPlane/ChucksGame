generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  stats     UserStats?
  matches   MatchParticipant[]
}

model UserStats {
  id                 String @id @default(uuid())
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id])

  totalMatches       Int    @default(0)
  totalWins          Int    @default(0)
  totalRunsScored    Int    @default(0)
  highestScore       Int    @default(0)
  totalWickets       Int    @default(0)
  totalRunsConceded  Int    @default(0)
}

model Match {
  id           String   @id @default(uuid())
  winningTeam  String
  teamAScore   Int
  teamBScore   Int
  createdAt    DateTime @default(now())

  participants MatchParticipant[]
}

model MatchParticipant {
  id              String  @id @default(uuid())
  matchId         String
  userId          String

  team            String
  isCommonPlayer  Boolean @default(false)
  runsScored      Int     @default(0)
  wicketsTaken    Int     @default(0)
  runsConceded    Int     @default(0)

  match Match @relation(fields: [matchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}